{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/backblaze/refs/heads/main/json-structure/b2-native-api-finish-large-file-request-structure.json",
  "name": "FinishLargeFileRequest",
  "description": "FinishLargeFileRequest schema from Backblaze B2 Native API",
  "type": "object",
  "properties": {
    "fileId": {
      "type": "string",
      "description": "The file ID from b2_start_large_file",
      "example": "4_za71c4725f4f4a14a14a14a14a"
    },
    "partSha1Array": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "SHA1 checksums of each part in order"
    }
  },
  "required": [
    "fileId",
    "partSha1Array"
  ]
}